---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="End User License Agreement (EULA) - Boomger."
  slug="eula"
  description="Read Boomger’s End User License Agreement (EULA) outlining user rights, responsibilities, app usage terms, legal conditions, and platform policies."
>
  <main
    class="pt-10 pb-24 mx-6 sm:mx-12 lg:mx-24 max-w-5xl text-zinc-900 leading-relaxed"
  >
    <section class="space-y-4 mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">
        Boomger End User License Agreement (EULA)
